# Azure AD App 등록값 (https://portal.azure.com → App registrations → New)
# Authentication → Allow public client flows = Yes
# API permissions → Microsoft Graph → Delegated: Mail.ReadWrite, User.Read

MS365_CLIENT_ID=00000000-0000-0000-0000-000000000000

# 회사 테넌트 ID. 모르면 common 으로 두면 자동 (단 회사 차단 시 거부됨)
# Azure AD → Overview → Tenant ID 에서 확인
MS365_TENANT_ID=common
